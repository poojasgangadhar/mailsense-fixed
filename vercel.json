{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["backend/**", "public/**"]
      }
    }
  ],
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs22.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/dashboard(.*)", "dest": "backend/server.js" },
    { "src": "/", "dest": "backend/server.js" },
    { "src": "/(.*)", "dest": "backend/server.js" }
  ]
}